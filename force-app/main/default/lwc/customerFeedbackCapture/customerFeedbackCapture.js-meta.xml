<?xml version="1.0"?>
<!--
    Metadata configuration for the customerFeedbackCapture LWC.
    ────────────────────────────────────────────────────────────
    Key points:
    - isExposed = true  :  Makes the component visible in the OmniScript Designer's
                           "Custom Lightning Web Component" element list.
    - runtimeNamespace   :  Required for OmniScript Base Mixin compatibility.
                           Without this, the import of 'omnistudio/omniscriptBaseMixin'
                           would fail at runtime with a namespace error.
-->
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <isExposed>true</isExposed>
    <apiVersion>66.0</apiVersion>
    <runtimeNamespace>omnistudio</runtimeNamespace>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
    </targets>
</LightningComponentBundle>
